# ============================================
# 炒股智能分析 Agent — 环境变量配置模板
# 复制本文件为 .env 后填入真实值（.env 已被 .gitignore，不会提交）
# ============================================

# ===== AI 分析（必填：每日复盘的 LLM 解读）=====
DEEPSEEK_API_KEY=

# ===== 推送通知（至少配一个；全部留空则只生成报告、不推送）=====

# 1) GitHub Issue 推送 —— CI 环境由 GitHub Actions 自动注入，本地需用 Personal Access Token
GITHUB_TOKEN=
GITHUB_REPOSITORY=your-name/your-repo

# 2) PushPlus（微信推送）  https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# 3) Server 酱（微信推送） https://turbo.sct.ftqq.com/
SERVERCHAN_TOKEN=

# 4) Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 可选：iwencai 研报语义搜索（第三方 a-stock-data skill 使用）=====
IWENCAI_API_KEY=
IWENCAI_BASE_URL=https://openapi.iwencai.com
